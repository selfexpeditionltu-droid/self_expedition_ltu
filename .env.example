# Copy this file to .env.local and fill in your real values.
# All NEXT_PUBLIC_ variables are exposed to the browser.

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# Meta (Facebook) Pixel ID (numeric, e.g. 1234567890123456)
NEXT_PUBLIC_META_PIXEL_ID=

# Calendly booking page URL (e.g. https://calendly.com/your-name/consultation)
# Leave empty to hide the booking section entirely.
NEXT_PUBLIC_CALENDLY_URL=

# Your production domain (used to block cross-origin API abuse), e.g. https://selfexpedition.lt
NEXT_PUBLIC_SITE_URL=

# ── Lead notifications ────────────────────────────────────────────────────────
# Gmail address used to SEND notification emails (e.g. your own Gmail)
GMAIL_USER=

# Gmail App Password (16 chars, no spaces). Generate at:
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=

# ── Google Sheets lead tracker ────────────────────────────────────────────────
# Service account email from your downloaded JSON key (client_email field)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the JSON key (private_key field). Keep the \n escape sequences.
GOOGLE_PRIVATE_KEY=

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
LEADS_SHEET_ID=
